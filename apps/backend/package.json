{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@friends/backend",
  "version": "0.0.1",
  "description": "Friends Backend API - NestJS RESTful API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "NODE_ENV=development nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "start:prod:migrate": "NODE_ENV=production pnpm migration:run:prod && NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "NODE_ENV=test jest --config ./test/jest.unit.json",
    "test:unit": "NODE_ENV=test jest --config ./test/jest.unit.json",
    "test:watch": "NODE_ENV=test jest --config ./test/jest.unit.json --watch",
    "test:run": "NODE_ENV=test jest --config ./test/jest.unit.json --runInBand",
    "test:int": "NODE_ENV=test jest --config ./test/jest.integration.json --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest.e2e.json --runInBand",
    "test:all": "pnpm test:run && pnpm test:int && pnpm test:e2e",
    "test:coverage": "NODE_ENV=test jest --config ./test/jest.unit.json --coverage",
    "check:backend": "pnpm lint && pnpm test:all",
    "test:debug": "NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./test/jest.unit.json --runInBand",
    "clean": "rm -rf dist",
    "migration:generate": "typeorm migration:generate src/migrations/InitSchema --dataSource src/data-source.ts --require ts-node/register",
    "migration:run": "pnpm migration:run:local",
    "migration:run:local": "typeorm migration:run --dataSource src/data-source.ts",
    "migration:run:prod": "typeorm migration:run --dataSource dist/data-source.js",
    "migration:revert": "pnpm migration:revert:local",
    "migration:revert:local": "typeorm migration:revert --dataSource src/data-source.ts",
    "typeorm": "typeorm"
  },
  "dependencies": {
    "@friends/shared-types": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-microsoft": "^2.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.18",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-microsoft": "^2.1.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
