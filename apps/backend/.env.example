########################################
# Backend environment example (.env.example)
########################################

# Server
NODE_ENV=development
PORT=3000
# Logging level: fatal | error | warn | info | debug | trace | silent (default: info)
LOG_LEVEL=info

# Database (use DATABASE_* names to match backend config)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=friends_db
DATABASE_SSL=false

# TypeORM options
TYPEORM_SYNC=false
TYPEORM_LOGGING=true

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT

JWT_SECRET=replace-with-secure-random
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Google OAuth2
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=replace-with-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/auth/microsoft/callback

# Cloudinary (avatar storage/optimization)
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
# Optional: override avatar folder (default: friends/dev/avatars or friends/prod/avatars based on NODE_ENV)
# CLOUDINARY_AVATAR_FOLDER=friends/dev/avatars

# Frontend URL (used for OAuth redirects)
FRONTEND_URL="http://localhost:5173/friends-web/#"

# Notes:
# - Do NOT commit a real .env file with secrets.

# - Use your CI/CD provider or hosting panel to store real secrets.

